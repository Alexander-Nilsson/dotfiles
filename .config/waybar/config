{
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/bluetooth", "battery", "cpu", "pulseaudio","network", "custom/power"],

  "network": {
        "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "format-ethernet": "{ifname} ΎΔΒ",
        "format-disconnected": "ΎΔΒ", 
        "max-length": 50,
        "on-click": "kitty -e 'nmtui'"
	    //"on-click": "plasmawindowed org.kde.plasma.networkmanagement"
  }, 
  
  "tray": {
        "icon-size": 15,
        "spacing": 10
  },

  "clock": {
    //"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": " {:%Y-%m-%d} "
		//"on-click": "gnome-calendar"
  },

  "pulseaudio": {
    "format": "{volume}% {icon} ",
    //"format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth": "{volume}% {icon}",
    "format-bluetooth-muted": "Ύγσ {icon}",
    "format-muted": "0% {icon} ",
    "format-source": "{volume}% ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },

	"custom/power": {
		"format": "ΎΑΣ ",
		"on-click": "wlogout"
	},

  "custom/bluetooth": {
    "exec": "bluetoothctl show | grep 'Powered: yes' > /dev/null && (bluetoothctl info | grep 'Connected: yes' > /dev/null && echo ' ≤░Γ▒' || echo ' ≤░Γψ') || echo ' ≤░Γ▓'",
    "interval": 5,
    "tooltip": false,
    "on-click": "blueman-manager"
  },
  
  "battery": {
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ΎΘο",
    "format-plugged": "{capacity}% ΎΘο",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "interval": 30,
    "tooltip": true
    },

  "cpu": {
    "format": "{usage}% ΎΜδ",
    "tooltip": false,
    "interval": 5
  }
}
